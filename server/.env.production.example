# Copie ce fichier en .env.production et remplis les valeurs
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/junto_prod

# Génère une clé forte : openssl rand -base64 32
JWT_SECRET=REMPLACER_PAR_UNE_CLE_SECRETE_FORTE

PORT=3001
CLIENT_URL=https://TON_DOMAINE_FRONTEND.vercel.app
APP_URL=https://TON_DOMAINE_FRONTEND.vercel.app

# Twilio (optionnel)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
